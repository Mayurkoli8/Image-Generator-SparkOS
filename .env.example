DATABASE_URL="file:./dev.db"

# Required for real AI generation. Without it, the app creates a branded fallback poster.
OPENAI_API_KEY=""
OPENAI_IMAGE_MODEL="gpt-image-1.5"
OPENAI_IMAGE_QUALITY="medium"

# Public URL used in webhook responses. Render example: https://brandposter-ai.onrender.com
PUBLIC_APP_URL="http://localhost:3000"

# Local persistent storage.
LOCAL_STORAGE_DIR="./.data/storage"

# Optional protection for the n8n endpoint. Send this as x-webhook-secret.
WEBHOOK_SECRET=""

# Basic in-memory request limit per IP and route.
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="20"
